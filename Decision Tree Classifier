#import the necessary libraries
import pandas as pd
import numpy as np

#import the dataset
from google.colab import files
uploaded = files.upload()

import pandas as pd
import io
df = pd.read_excel(io.BytesIO(uploaded['Weather Data (4).xlsx']), header = 1)
print(df)

df.head()

df.shape

from sklearn.preprocessing import LabelEncoder
le = LabelEncoder()
df = df.apply(le.fit_transform)
print(df)

# defining the variables
x=df.drop(['PlayTennis'], axis = 1).values
print(x)

y = df['PlayTennis'].values
print(y)

#Data division model importation and model training
from sklearn.model_selection import train_test_split
x_train, x_test, y_train, y_test = train_test_split(x,y, test_size=0.3)

from sklearn.tree import DecisionTreeClassifier
classifier = DecisionTreeClassifier(criterion = 'entropy',splitter = 'best')
classifier.fit(x_train,y_train)

#model testing 
y_pred =classifier.predict(x_test)
print(y_pred)

#importation of model performance metrics to the determine the model's predictive performance
from sklearn.metrics import accuracy_score
accuracy_score(y_test,y_pred)

#plotting the outcome of the prediction
import matplotlib.pyplot as plt
from sklearn import tree
fig, axes = plt.subplots(nrows=1, ncols=1, figsize=(4,4), dpi=100)
tree.plot_tree(classifier)


